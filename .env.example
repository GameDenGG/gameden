# Local development
DATABASE_URL=postgresql://postgres:YOURPASSWORD@localhost:5432/newworld

# Production example
# DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>

# Public brand/domain metadata
DISPLAY_SITE_NAME=GameDen.gg
# Legacy alias (optional): SITE_NAME=GameDen.gg
SITE_URL=https://gameden.gg
# Optional override for default page metadata description
# SITE_DESCRIPTION=Discover game deals, analytics, player trends, and price history on GameDen.gg.

# Optional canonical host redirect behavior (recommended for production)
CANONICAL_HOST_REDIRECT=false
# Comma-separated non-canonical hosts that should redirect to SITE_URL host
CANONICAL_REDIRECT_HOSTS=www.gameden.gg

# API CORS allowlist (comma-separated origins)
# Keep production origins + local dev origins here.
CORS_ALLOW_ORIGINS=https://gameden.gg,https://www.gameden.gg,http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
# Dev-only escape hatch; if true, CORS_ALLOW_ORIGINS is ignored and "*" is used.
CORS_ALLOW_ALL_ORIGINS=false

# Ingestion pacing / sharding (safe defaults)
TRACK_GAMES_PER_RUN=600
TRACK_GAMES_PER_RUN_LIMIT=1000
TRACK_MIN_DELAY_SECONDS=0.05
TRACK_MAX_DELAY_SECONDS=0.20
TRACK_REQUEST_RETRIES=2
TRACK_SHARD_TOTAL=1
TRACK_SHARD_INDEX=0

# Priority-tier refresh cadence (minutes)
TRACK_HOT_REFRESH_MINUTES=20
TRACK_MEDIUM_REFRESH_MINUTES=180
TRACK_COLD_REFRESH_MINUTES=1440

# Catalog rollout hold controls
TRACK_ROLLOUT_HOLD_TIER=ROLLOUT_HOLD
TRACK_INCLUDE_ROLLOUT_HOLD=false

# Snapshot batching / queue backoff
SNAPSHOT_BATCH_SIZE=200
SNAPSHOT_MAX_BATCH_SIZE=1000
SNAPSHOT_RETRY_BACKOFF_BASE_SECONDS=30
SNAPSHOT_RETRY_BACKOFF_MAX_SECONDS=3600

# Homepage candidate pool sizing
HOMEPAGE_DEAL_CANDIDATE_POOL=384
